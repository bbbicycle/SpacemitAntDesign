{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "dist/theme",
    "outDir": "dist/theme",
    "rootDir": "src/theme"
  },
  "include": ["src/theme/**/*.ts", "src/theme/**/*.json"]
}
